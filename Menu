minimizedFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isDragging = true
		dragStart = input.Position
		startPos = minimizedFrame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if isDragging then
		local delta = input.Position - dragStart
		local newPosition = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		if mainFrame.Visible then
			mainFrame.Position = newPosition
		elseif minimizedFrame.Visible then
			minimizedFrame.Position = newPosition
		end
	end
	
	if isDraggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local sliderPos = speedSlider.AbsolutePosition
		local sliderSize = speedSlider.AbsoluteSize
		local mousePos = input.Position
		local relativeX = math.clamp(mousePos.X - sliderPos.X, 0, sliderSize.X)
		local percentage = relativeX / sliderSize.X
		local speed = math.floor(minSpeed + (maxSpeed - minSpeed) * percentage)
		sliderButton.Position = UDim2.new(percentage, -8, 0.5, -8)
		currentSpeed = speed
		speedButton.Text = "Скорость: " .. speed
		if player.Character and player.Character:FindFirstChild("Humanoid") then
			player.Character.Humanoid.WalkSpeed = speed
		end
	end
	
	if isDraggingJump and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local sliderPos = jumpSlider.AbsolutePosition
		local sliderSize = jumpSlider.AbsoluteSize
		local mousePos = input.Position
		local relativeX = math.clamp(mousePos.X - sliderPos.X, 0, sliderSize.X)
		local percentage = relativeX / sliderSize.X
		local newJump = math.floor(minJump + (maxJump - minJump) * percentage)
		jumpSliderButton.Position = UDim2.new(percentage, -8, 0.5, -8)
		currentJump = newJump
		jumpButton.Text = "Прыжок: " .. newJump
		if player.Character and player.Character:FindFirstChild("Humanoid") then
			player.Character.Humanoid.JumpPower = newJump
		end
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isDragging = false
		isDraggingSlider = false
		isDraggingJump = false
	end
end)

