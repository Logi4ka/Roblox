	if not enterPressed then
		speedInput.Visible = false
		speedButton.Visible = true
		speedInput.Text = tostring(currentSpeed)
		return
	end
	local inputSpeed = tonumber(speedInput.Text)
	if inputSpeed then
		inputSpeed = math.clamp(inputSpeed, minSpeed, maxSpeed)
		currentSpeed = inputSpeed
		local percentage = (inputSpeed - minSpeed) / (maxSpeed - minSpeed)
		sliderButton.Position = UDim2.new(percentage, -8, 0.5, -8)
		if player.Character and player.Character:FindFirstChild("Humanoid") then
			player.Character.Humanoid.WalkSpeed = inputSpeed
		end
	else
		inputSpeed = currentSpeed
	end
	speedButton.Text = "Скорость: " .. inputSpeed
	speedInput.Visible = false
	speedButton.Visible = true
end)

