UserInputService.InputChanged:Connect(function(input)
	updateDrag(input)
	-- Обработка слайдеров скорости и прыжка
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		-- Скорость
		if speedControl.dragging then
			local sliderPos = speedControl.Slider.AbsolutePosition
			local sliderSize = speedControl.Slider.AbsoluteSize
			local relativeX = math.clamp(input.Position.X - sliderPos.X, 0, sliderSize.X)
			local perc = relativeX / sliderSize.X
			local newSpeed = math.floor(minSpeed + (maxSpeed - minSpeed) * perc)
			speedControl.SliderButton.Position = UDim2.new(perc, -8, 0.5, -8)
			currentSpeed = newSpeed
			speedControl.Button.Text = "Скорость: " .. newSpeed
			if player.Character and player.Character:FindFirstChild("Humanoid") then
				player.Character.Humanoid.WalkSpeed = newSpeed
			end
		end
		-- Прыжок
		if jumpControl.dragging then
			local sliderPos = jumpControl.Slider.AbsolutePosition
			local sliderSize = jumpControl.Slider.AbsoluteSize
			local relativeX = math.clamp(input.Position.X - sliderPos.X, 0, sliderSize.X)
			local perc = relativeX / sliderSize.X
			local newJump = math.floor(minJump + (maxJump - minJump) * perc)
			jumpControl.SliderButton.Position = UDim2.new(perc, -8, 0.5, -8)
			currentJump = newJump
			jumpControl.Button.Text = "Прыжок: " .. newJump
			if player.Character and player.Character:FindFirstChild("Humanoid") then
				player.Character.Humanoid.JumpPower = newJump
			end
		end
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isDragging = false
		speedControl.dragging = false
		jumpControl.dragging = false
	end
end)

