-- Создание слайдеров для скорости и прыжка

local function createSlider(parent, labelText, initialVal, minVal, maxVal, posY)
	local container = create("Frame", {
		Size = UDim2.new(0,200,0,60),
		Position = UDim2.new(0,0,0,posY),
		BackgroundTransparency = 1,
		Active = true,
		Selectable = true,
	}, parent)
	
	local button = createButton("Button", labelText .. ": " .. initialVal, UDim2.new(0.9,0,0,40), UDim2.new(0.05,0,0,0), container)
	local input = create("TextBox", {
		Size = button.Size,
		Position = button.Position,
		BackgroundColor3 = Color3.fromRGB(65,65,65),
		BorderSizePixel = 0,
		TextColor3 = Color3.fromRGB(255,255,255),
		TextSize = 14,
		Font = Enum.Font.Gotham,
		Text = tostring(initialVal),
		ClearTextOnFocus = true,
		Visible = false,
		Active = true,
		Selectable = true,
	}, container)
	-- Фильтр ввода: только цифры
	input:GetPropertyChangedSignal("Text"):Connect(function()
		local newText = input.Text:match("^%d*$") or ""
		if newText ~= input.Text then
			input.Text = newText
		end
	end)
	
	local slider = create("Frame", {
		Size = UDim2.new(0.9,0,0,4),
		Position = UDim2.new(0.05,0,0,50),
		BackgroundColor3 = Color3.fromRGB(65,65,65),
		BorderSizePixel = 0,
		Active = true,
		Selectable = true,
	}, container)
	create("UICorner", { CornerRadius = UDim.new(1,0) }, slider)
	local initPerc = (initialVal - minVal) / (maxVal - minVal)
	local sliderButton = create("TextButton", {
		Size = UDim2.new(0,16,0,16),
		Position = UDim2.new(initPerc, -8, 0.5, -8),
		BackgroundColor3 = Color3.fromRGB(255,255,255),
		BorderSizePixel = 0,
		Text = "",
		Active = true,
		Selectable = true,
	}, slider)
	create("UICorner", { CornerRadius = UDim.new(1,0) }, sliderButton)
	
	return {
		Container = container,
		Button = button,
		Input = input,
		Slider = slider,
		SliderButton = sliderButton,
		Min = minVal,
		Max = maxVal,
		LabelText = labelText,
		dragging = false,
		SetValue = function(self, newVal)
			newVal = math.clamp(newVal, self.Min, self.Max)
			local perc = (newVal - self.Min) / (self.Max - self.Min)
			self.SliderButton.Position = UDim2.new(perc, -8, 0.5, -8)
			self.Button.Text = self.LabelText .. ": " .. newVal
		end
	}
end

