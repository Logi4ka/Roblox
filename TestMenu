-- Перетаскивание окна (основного и свернутого)
local function startDrag(input, frame)
	isDragging = true
	dragStart = input.Position
	startPos = frame.Position
end

titleBar.InputBegan:Connect(function(input)
	if isMouseOrTouch(input) then
		startDrag(input, mainFrame)
	end
end)
minimizedFrame.InputBegan:Connect(function(input)
	if isMouseOrTouch(input) then
		startDrag(input, minimizedFrame)
	end
end)
UserInputService.InputChanged:Connect(function(input)
	if isDragging then
		local delta = input.Position - dragStart
		local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		if mainFrame.Visible then
			mainFrame.Position = newPos
		elseif minimizedFrame.Visible then
			minimizedFrame.Position = newPos
		end
	end
	-- Обработка перемещения ползунков (скорость)
	if isDraggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local sliderPos = speedFrameData.Slider.AbsolutePosition
		local sliderSize = speedFrameData.Slider.AbsoluteSize
		local relativeX = math.clamp(input.Position.X - sliderPos.X, 0, sliderSize.X)
		local percentage = relativeX / sliderSize.X
		local speed = math.floor(speedFrameData.Min + (speedFrameData.Max - speedFrameData.Min) * percentage)
		speedFrameData.SliderButton.Position = UDim2.new(percentage, -8, 0.5, -8)
		currentSpeed = speed
		speedFrameData.Button.Text = "Скорость: " .. speed
		if player.Character and player.Character:FindFirstChild("Humanoid") then
			player.Character.Humanoid.WalkSpeed = speed
		end
	end
	-- Обработка перемещения ползунка (прыжок)
	if isDraggingJump and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local sliderPos = jumpFrameData.Slider.AbsolutePosition
		local sliderSize = jumpFrameData.Slider.AbsoluteSize
		local relativeX = math.clamp(input.Position.X - sliderPos.X, 0, sliderSize.X)
		local percentage = relativeX / sliderSize.X
		local jumpVal = math.floor(jumpFrameData.Min + (jumpFrameData.Max - jumpFrameData.Min) * percentage)
		jumpFrameData.SliderButton.Position = UDim2.new(percentage, -8, 0.5, -8)
		currentJump = jumpVal
		jumpFrameData.Button.Text = "Прыжок: " .. jumpVal
		if player.Character and player.Character:FindFirstChild("Humanoid") then
			player.Character.Humanoid.JumpPower = jumpVal
		end
	end
end)
UserInputService.InputEnded:Connect(function(input)
	if isMouseOrTouch(input) then
		isDragging = false
		isDraggingSlider = false
		isDraggingJump = false
	end
end)

