-- Функция для создания фрейма с ползунком и вводом (для скорости и прыжка)
local function createSliderFrame(name, buttonText, positionY, currentValue, minValue, maxValue, parent)
	local frame = create("Frame", {
		Name = name,
		Size = UDim2.new(0,200,0,60),
		Position = UDim2.new(0,0,0,positionY),
		BackgroundTransparency = 1,
		Active = true,
		Selectable = true,
		Parent = parent,
	})
	
	local btn = create("TextButton", {
		Size = UDim2.new(0.9,0,0,40),
		Position = UDim2.new(0.05,0,0,0),
		BackgroundColor3 = Color3.fromRGB(65,65,65),
		BorderSizePixel = 0,
		TextColor3 = Color3.new(1,1,1),
		TextSize = 14,
		Font = Enum.Font.Gotham,
		Text = buttonText .. currentValue,
		Active = true,
		Selectable = true,
		Parent = frame,
	})
	
	local input = create("TextBox", {
		Size = btn.Size,
		Position = btn.Position,
		BackgroundColor3 = btn.BackgroundColor3,
		BorderSizePixel = 0,
		TextColor3 = btn.TextColor3,
		TextSize = btn.TextSize,
		Font = btn.Font,
		Text = tostring(currentValue),
		ClearTextOnFocus = true,
		Visible = false,
		Active = true,
		Selectable = true,
		Parent = frame,
	})
	-- Фильтрация ввода (только цифры)
	input:GetPropertyChangedSignal("Text"):Connect(function()
		local newText = input.Text:match("^%d*$") or ""
		if newText ~= input.Text then
			input.Text = newText
		end
	end)
	
	local slider = create("Frame", {
		Size = UDim2.new(0.9,0,0,4),
		Position = UDim2.new(0.05,0,0,50),
		BackgroundColor3 = Color3.fromRGB(65,65,65),
		BorderSizePixel = 0,
		Active = true,
		Selectable = true,
		Parent = frame,
	})
	create("UICorner", {CornerRadius = UDim.new(1,0), Parent = slider})
	
	local initPerc = (currentValue - minValue) / (maxValue - minValue)
	local sliderButton = create("TextButton", {
		Size = UDim2.new(0,16,0,16),
		Position = UDim2.new(initPerc, -8, 0.5, -8),
		BackgroundColor3 = Color3.new(1,1,1),
		BorderSizePixel = 0,
		Text = "",
		Active = true,
		Selectable = true,
		Parent = slider,
	})
	create("UICorner", {CornerRadius = UDim.new(1,0), Parent = sliderButton})
	
	return {
		Frame = frame,
		Button = btn,
		Input = input,
		Slider = slider,
		SliderButton = sliderButton,
		Min = minValue,
		Max = maxValue,
		Update = function(newVal)
			local percentage = (newVal - minValue) / (maxValue - minValue)
			sliderButton.Position = UDim2.new(percentage, -8, 0.5, -8)
			btn.Text = buttonText .. newVal
		end
	}
end

